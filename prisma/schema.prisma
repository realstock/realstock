generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {

  id Int @id @default(autoincrement())
  
  name     String
  email    String @unique
  password String
  avatar    String?
  bio       String?
  cpfCnpj   String?
  phone     String?
  instagram String?
  country String?
  state   String?
  city    String?
  
paypalEmail String?
  
  role     String  @default("USER")
  verified Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  properties Property[]
  offers     Offer[]    @relation("BuyerOffers")

  @@map("users")
}

model Property {
	
  id                  Int      @id @default(autoincrement())
  title               String
  description         String?
  price               Decimal
  legalStatus         String   @map("legal_status")
  area                String
  country             String?  @default("Brasil")
  state               String?
  city                String
  neighborhood        String?
  street              String?
  addressNumber       String?  @map("address_number")
  zipCode             String?  @map("zip_code")
  googleMapsLink      String?  @map("google_maps_link")
  googleMapsThumbnail String?  @map("google_maps_thumbnail")
  youtubeLink         String?  @map("youtube_link")
  youtubeThumbnail    String?  @map("youtube_thumbnail")
  topographyPoints    String?  @map("topography_points")
  category            String?
  propertyType        String?  @map("property_type")
  areaBuilt           String?  @map("area_built")
  bedrooms            Int?
  bathrooms           Int?
  parkingSpaces       Int?     @map("parking_spaces")
  suites              Int?
  furnished           Boolean  @default(false)
  condominium         Boolean  @default(false)
  condominiumFee      Decimal? @map("condominium_fee")
  acceptsFinancing    Boolean  @default(false) @map("accepts_financing")
  frontSea            Boolean  @default(false) @map("front_sea")
  pool                Boolean  @default(false)
  latitude            Decimal
  longitude           Decimal
  ownerId             Int      @map("owner_id")
  createdAt           DateTime @default(now()) @map("created_at")

  owner  User            @relation(fields: [ownerId], references: [id])
  images PropertyImage[]
  offers Offer[]

  @@map("properties")
}

model PropertyImage {
  id         Int      @id @default(autoincrement())
  propertyId Int      @map("property_id")
  imageUrl   String   @map("image_url")
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")

  property Property @relation(fields: [propertyId], references: [id])

  @@map("property_images")
}

model Offer {
  id         Int      @id @default(autoincrement())
  propertyId Int      @map("property_id")
  buyerId    Int      @map("buyer_id")
  offerPrice Decimal  @map("offer_price")
  status     String   @default("open")
  createdAt  DateTime @default(now()) @map("created_at")

  property Property @relation(fields: [propertyId], references: [id])
  buyer    User     @relation("BuyerOffers", fields: [buyerId], references: [id])

  @@map("offers")
}

model OfferPayment {
  id                 Int       @id @default(autoincrement())
  offerId            Int       @map("offer_id")
  propertyId         Int       @map("property_id")
  buyerId            Int       @map("buyer_id")
  sellerId           Int       @map("seller_id")
  acceptedOfferValue Decimal   @map("accepted_offer_value")
  paymentAmount      Decimal   @map("payment_amount")
  paypalOrderId      String?   @map("paypal_order_id")
  paypalCaptureId    String?   @map("paypal_capture_id")
  paymentStatus      String    @default("pending") @map("payment_status")
  contactReleased    Boolean   @default(false) @map("contact_released")
  createdAt          DateTime  @default(now()) @map("created_at")
  paidAt             DateTime? @map("paid_at")

  @@map("offer_payments")
}
