generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  USER
  ADMIN
}

model InstagramPreviewSession {
  id                    String   @id @default(cuid())
  listingId             Int
  caption               String?
  status                String   @default("DRAFT")
  allImageUrls          Json
  selectedImages        Json
  validationReport      Json?
  publishErrors         Json?
  containerIds          Json?
  publishedMediaId      String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model User {
  id          Int        @id @default(autoincrement())
  email       String     @unique
  instagram   String?
  password    String
  avatar      String?
  bio         String?
  city        String?
  country     String?
  cpfCnpj     String?
  createdAt   DateTime   @default(now())
  name        String
  paypalEmail String?
  phone       String?
  role        String     @default("USER")
  state       String?
  updatedAt   DateTime   @updatedAt
  verified    Boolean    @default(false)
  offers      Offer[]    @relation("BuyerOffers")
  properties  Property[]

  @@map("users")
}

model Property {
  id                  Int             @id @default(autoincrement())
  title               String
  description         String?
  price               Decimal
  legalStatus         String          @map("legal_status")
  area                String
  city                String
  neighborhood        String?
  category            String?
  propertyType        String?         @map("property_type")
  areaBuilt           String?         @map("area_built")
  bedrooms            Int?
  bathrooms           Int?
  parkingSpaces       Int?            @map("parking_spaces")
  suites              Int?
  furnished           Boolean         @default(false)
  condominium         Boolean         @default(false)
  condominiumFee      Decimal?        @map("condominium_fee")
  acceptsFinancing    Boolean         @default(false) @map("accepts_financing")
  frontSea            Boolean         @default(false) @map("front_sea")
  pool                Boolean         @default(false)
  latitude            Decimal
  longitude           Decimal
  ownerId             Int             @map("owner_id")
  createdAt           DateTime        @default(now()) @map("created_at")
  country             String?         @default("Brasil")
  googleMapsLink      String?         @map("google_maps_link")
  state               String?
  street              String?
  zipCode             String?         @map("zip_code")
  addressNumber       String?         @map("address_number")
  googleMapsThumbnail String?         @map("google_maps_thumbnail")
  topographyPoints    String?         @map("topography_points")
  youtubeLink         String?         @map("youtube_link")
  youtubeThumbnail    String?         @map("youtube_thumbnail")
  offers              Offer[]
  owner               User            @relation(fields: [ownerId], references: [id])
  images              PropertyImage[]

  @@map("properties")
}

model PropertyImage {
  id         Int      @id @default(autoincrement())
  propertyId Int      @map("property_id")
  imageUrl   String   @map("image_url")
  sortOrder  Int      @default(0) @map("sort_order")
  createdAt  DateTime @default(now()) @map("created_at")
  property   Property @relation(fields: [propertyId], references: [id])

  @@map("property_images")
}

model Offer {
  id         Int      @id @default(autoincrement())
  propertyId Int      @map("property_id")
  buyerId    Int      @map("buyer_id")
  offerPrice Decimal  @map("offer_price")
  status     String   @default("open")
  createdAt  DateTime @default(now()) @map("created_at")
  buyer      User     @relation("BuyerOffers", fields: [buyerId], references: [id])
  property   Property @relation(fields: [propertyId], references: [id])

  @@map("offers")
}

model OfferPayment {
  id                 Int       @id @default(autoincrement())
  offerId            Int       @map("offer_id")
  propertyId         Int       @map("property_id")
  buyerId            Int       @map("buyer_id")
  sellerId           Int       @map("seller_id")
  acceptedOfferValue Decimal   @map("accepted_offer_value")
  paymentAmount      Decimal   @map("payment_amount")
  paypalOrderId      String?   @map("paypal_order_id")
  paypalCaptureId    String?   @map("paypal_capture_id")
  paymentStatus      String    @default("pending") @map("payment_status")
  contactReleased    Boolean   @default(false) @map("contact_released")
  createdAt          DateTime  @default(now()) @map("created_at")
  paidAt             DateTime? @map("paid_at")

  @@map("offer_payments")
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int      @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("password_reset_tokens")
}



